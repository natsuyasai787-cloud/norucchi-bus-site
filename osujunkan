<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>大洲循環線 C30 日曜テスト</title>

<style>
body{
margin:0;
background:#000;
color:#fff;
font-family:sans-serif;
text-align:center;
}

header{
padding:20px;
border-bottom:3px solid #ffd000;
}

h1{
color:#ffd000;
}

#clock{
font-size:24px;
margin-top:10px;
}

.line{
position:relative;
width:8px;
height:1800px;
background:#fff;
margin:40px auto;
}

.stop{
position:absolute;
left:50%;
transform:translateX(-50%);
width:220px;
background:#111;
border:2px solid #333;
border-radius:20px;
padding:15px;
font-size:24px;
font-weight:bold;
}

.bus{
position:absolute;
left:-80px;
top:10px;
width:55px;
height:55px;
border-radius:50%;
background:#008cff;
display:flex;
align-items:center;
justify-content:center;
font-size:28px;
box-shadow:0 0 20px #008cff;
}
</style>
</head>

<body>

<header>
<h1>大洲循環線 C30（日曜）</h1>
<div id="clock"></div>
</header>

<div class="line">

<div class="stop" id="stop0" style="top:0px;">上野</div>
<div class="stop" id="stop1" style="top:120px;">大分駅前</div>
<div class="stop" id="stop2" style="top:240px;">中央通り</div>
<div class="stop" id="stop3" style="top:360px;">県庁前</div>
<div class="stop" id="stop4" style="top:480px;">競技場前</div>
<div class="stop" id="stop5" style="top:600px;">大津町一丁目</div>
<div class="stop" id="stop6" style="top:720px;">大洲運動公園前</div>
<div class="stop" id="stop7" style="top:840px;">商業高校前</div>
<div class="stop" id="stop8" style="top:960px;">古ヶ鶴公民館入口</div>
<div class="stop" id="stop9" style="top:1080px;">県庁前</div>
<div class="stop" id="stop10" style="top:1200px;">中央通り③</div>
<div class="stop" id="stop11" style="top:1320px;">中央通り④</div>
<div class="stop" id="stop12" style="top:1440px;">大分駅前③</div>
<div class="stop" id="stop13" style="top:1560px;">大分駅前</div>
<div class="stop" id="stop14" style="top:1680px;">上野</div>

</div>

<script>

function clock(){

const n=new Date();

document.getElementById("clock").innerHTML=
String(n.getHours()).padStart(2,"0")
+":"
+String(n.getMinutes()).padStart(2,"0")
+":"
+String(n.getSeconds()).padStart(2,"0");

}

setInterval(clock,1000);

clock();

/* 日曜C30 10時〜11時 */

const sunday=[

[1000,1002,1004,1006,1008,1010,1012,1014,1016,1018,1020,1022,1024,1026,1028],
[1030,1032,1034,1036,1038,1040,1042,1044,1046,1048,1050,1052,1054,1056,1058]

];

function drawBus(i){

const stop=document.getElementById(
"stop"+i
);

if(!stop)return;

const bus=document.createElement("div");

bus.className="bus";

bus.innerHTML="🚌";

stop.appendChild(bus);

}

function update(){

document
.querySelectorAll(".bus")
.forEach(b=>b.remove());

const n=new Date();

const now=
n.getHours()*100
+
n.getMinutes();

sunday.forEach(t=>{

for(let i=0;i<t.length;i++){

if(now>=t[i] && now<t[i]+2){

drawBus(i);

}

}

});

}

setInterval(update,1000);

update();

</script>

</body>
</html>
